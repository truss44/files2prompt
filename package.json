{
  "name": "files2prompt",
  "version": "2.2.5",
  "description": "A CLI tool to read files/directories and format them as prompts for LLMs (e.g., XML for Claude). Cross-platform (Windows/WSL2/Linux).",
  "author": "Tracey Russell",
  "license": "MIT",
  "main": "./dist/index.js",
  "bin": {
    "files2prompt": "./dist/cli.js",
    "files2prompt-cli": "./dist/cli.js",
    "f2p": "./dist/cli.js",
    "f2p-cli": "./dist/cli.js"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "dist/**/*"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepublishOnly": "pnpm build",
    "start": "node dist/cli.js",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "release": "semantic-release"
  },
  "keywords": [
    "cli",
    "llm",
    "prompt",
    "files",
    "codebase",
    "claude",
    "xml"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^25.0.5",
    "test-exclude": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/truss44/files2prompt.git"
  },
  "bugs": {
    "url": "https://github.com/truss44/files2prompt/issues"
  },
  "homepage": "https://github.com/truss44/files2prompt"
}
